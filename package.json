{
  "name": "@particle-academy/fancy-slides",
  "version": "0.15.0",
  "description": "Presentation editor + web viewer for the fancy UI set — Google-Slides-style deck authoring with a JSON-friendly schema, full keyboard-driven viewer, and an agent bridge so LLMs can compose decks directly.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-slides.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-slides#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-slides/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./registry": {
      "import": "./dist/registry.js",
      "require": "./dist/registry.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "slides",
    "presentation",
    "slideshow",
    "deck",
    "agent",
    "fancy",
    "human-plus"
  ],
  "peerDependencies": {
    "@particle-academy/fancy-code": "^0.4.0 || ^0.5.0",
    "@particle-academy/fancy-echarts": "^3.0.0 || ^4.0.0",
    "@particle-academy/react-fancy": ">=3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@particle-academy/fancy-code": "^0.4.0 || ^0.5.0",
    "@particle-academy/fancy-echarts": "^4.0.0",
    "@particle-academy/react-fancy": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ]
}
